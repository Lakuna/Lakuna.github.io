{
	"compilerOptions": {
		"allowJs": false, // Next.js required.
		"allowUnreachableCode": false,
		"allowUnusedLabels": false,
		"composite": true,
		"esModuleInterop": true, // Next.js required.
		"exactOptionalPropertyTypes": true,
		"incremental": true, // Next.js required.
		"isolatedDeclarations": true,
		"isolatedModules": true, // Next.js required.
		"jsx": "react-jsx", // Next.js required.
		"lib": ["DOM", "ESNext"], // Next.js required.
		"module": "esnext", // Next.js required.
		"moduleResolution": "bundler", // Next.js required.
		"noEmit": true, // Next.js required.
		"noFallthroughCasesInSwitch": true,
		"noImplicitOverride": true,
		"noImplicitReturns": true,
		"noPropertyAccessFromIndexSignature": true,
		"noUncheckedIndexedAccess": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"paths": { "@/*": ["./src/*"] },
		"plugins": [{ "name": "@mdx-js/typescript-plugin" }, { "name": "next" }], // Next.js required.
		"resolveJsonModule": true, // Next.js required.
		"skipLibCheck": true, // Next.js required.
		"strict": true, // Next.js required.
		"target": "esnext", // Next.js required.
		"verbatimModuleSyntax": true
	},
	"exclude": ["dist", "docs", "node_modules"], // Next.js required.
	"include": ["**/*", ".next/dev/types/**/*.ts", ".next/types/**/*.ts"], // Next.js required.
	"mdx": {
		// https://github.com/mdx-js/mdx-analyzer
		"checkMdx": true,
		"plugins": [["remark-frontmatter", ["yaml"]], "remark-math"]
	}
}
